let ssmPremiumConfig={target:"div[data-fullimg]>div>a",logo:"https://wallpaper.dog/logob.png",mainColor:"#2185d0",buttonClass:"ui small blue button download_button ssmButton",buttonStyle:"line-height:25px;height:auto;min-height:40px;display:block;margin-top:10px;margin-bottom:10px",titleText:"",titleStyle:"margin-top:15px;font-size:25px",subTitleText:"Before downloading the wallpaper you will see a short advertisement.",explainText:"",callToActionText:'<i class="download_icon icon"></i> Download Wallpapper and Watch Ad'}
class ssmPremiumContent{constructor(config){this.config=config;googletag.cmd.push(()=>{if(window.location.href.indexOf("ssmDemo")>-1){var rewardedSlot=googletag.defineOutOfPageSlot('/22582250850/REWARDED_DEMO',googletag.enums.OutOfPageFormat.REWARDED);}
else{var rewardedSlot=googletag.defineOutOfPageSlot('/78011819,22990910134/REWARDED',googletag.enums.OutOfPageFormat.REWARDED);}
window.ssmRegardedSlot=rewardedSlot;if(rewardedSlot)
{console.log("SSM => SS+SponsorWall ready");rewardedSlot.addService(googletag.pubads());googletag.display(rewardedSlot);console.log("SSM => display SS+SponsorWall");}
if(googletag.pubads().isInitialLoadDisabled()){googletag.pubads().refresh([window.ssmRegardedSlot]);console.log("SSM => refreshing SS+SponsorWall");}
googletag.pubads().addEventListener('rewardedSlotReady',event=>{console.log("SSM => Regarded Enable NoEMPTY")
this.createPremiumContainer();window.ssmDispatchRegardedEvent=event;});});}
createPremiumContainer(){if(document.querySelector(this.config.target)){let ssmPremiumContainer=document.createElement("ins");ssmPremiumContainer.id="ssmPremiumContainer";ssmPremiumContainer.setAttribute("style","transition: 0.3s all linear;animation: ssmMoveUpDown 1s linear;text-decoration:none;padding-top: 10px;padding-bottom: 130px; background: linear-gradient(rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 1) 500px, rgb(255, 255, 255) 200px, rgb(249, 249, 249, 1) 200px, rgba(252, 252, 252, 1) 500px, rgba(253, 253, 253, 0.95) 700px);width: 100%;left:0px;position: absolute;display: flex;z-index: 1000099;border-radius: 20px 20px 0px 0px;box-shadow: 0px -5px 5px #0000004f;");ssmPremiumContainer.style.position="fixed";ssmPremiumContainer.style.bottom=(window.outerHeight+window.outerHeight/2)*-1+"px";ssmPremiumContainer.style.zIndex=this.maxZIndex()+100;var ssmTargetContainer=document.querySelector("div.single_image");ssmTargetContainer.appendChild(ssmPremiumContainer);let ssmPremiumText=document.createElement("div");ssmPremiumText.id="ssmPremiumText";ssmPremiumText.setAttribute("style","width:100%;");ssmPremiumText.innerHTML='<div id="ssmCloseButton" style="position:absolute;right: 10px;padding: 10px;cursor: pointer;background: rgb(96 97 99 / 15%);height: 45px;border-radius: 25px;"><svg height="24px" width="24px" id="Layer_1" style="enable-background:new 0 0 512 512;" version="1.1" viewBox="0 0 512 512"  xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><path d="M443.6,387.1L312.4,255.4l131.5-130c5.4-5.4,5.4-14.2,0-19.6l-37.4-37.6c-2.6-2.6-6.1-4-9.8-4c-3.7,0-7.2,1.5-9.8,4  L256,197.8L124.9,68.3c-2.6-2.6-6.1-4-9.8-4c-3.7,0-7.2,1.5-9.8,4L68,105.9c-5.4,5.4-5.4,14.2,0,19.6l131.5,130L68.4,387.1  c-2.6,2.6-4.1,6.1-4.1,9.8c0,3.7,1.4,7.2,4.1,9.8l37.4,37.6c2.7,2.7,6.2,4.1,9.8,4.1c3.5,0,7.1-1.3,9.8-4.1L256,313.1l130.7,131.1  c2.7,2.7,6.2,4.1,9.8,4.1c3.5,0,7.1-1.3,9.8-4.1l37.4-37.6c2.6-2.6,4.1-6.1,4.1-9.8C447.7,393.2,446.2,389.7,443.6,387.1z"/></svg></div><center><img src="'+this.config.logo+'" style="height:40px"/></center><div style="border-top: solid '+this.config.mainColor+' 7px;margin-top:10px"><div style="padding-left:10px;padding-right:10px;"><center><h3 style="'+this.config.titleStyle+'"><strong>'+this.config.titleText+'</strong></h3><h3>'+this.config.subTitleText+'</h3><button id="ssmRegardedButton" class="'+this.config.buttonClass+'" style="'+this.config.buttonStyle+'">'+this.config.callToActionText+'</button><i>'+this.config.explainText+'</i></center></div></div>';ssmPremiumContainer.appendChild(ssmPremiumText);document.body.appendChild(ssmPremiumContainer);document.querySelector("#ssmCloseButton").addEventListener("click",()=>{ssmPremiumContainer.style.bottom=(-10+ssmPremiumContainer.getBoundingClientRect().height*-1)+"px";})
document.oncontextmenu=function(){return false}
document.querySelectorAll('.thumb.ads_popup').forEach((element)=>{element.addEventListener('mousedown',(e)=>{e.stopImmediatePropagation();e.stopPropagation();},true)})
document.querySelectorAll("div[data-pin] a").forEach((a)=>{a.href='javascript:void(0)'
a.target="_self"
a.style.cursor='initial'
a.classList.remove("ads_popup");a.click=function(){return false}})
document.querySelectorAll("div.flexbox_item.bottom_panel a.download_button").forEach((button)=>{button.style.display='none';var ssmA=document.createElement("a");ssmA.innerHTML='<span class="ui inverted"><i class="download_icon icon"></i><span class="download_text"> Download Wallpapper</span></span>';ssmA.setAttribute("class","ui small blue button download_button ssmButton");ssmA.setAttribute("style","display: block;");var self=this
ssmA.addEventListener("click",()=>{ssmPremiumContainer.style.bottom="0px";ssmPremiumContainer.style.top="auto";document.getElementById("ssmRegardedButton").addEventListener("click",()=>{self.run(button)
self.showRegarded();});});button.parentElement.appendChild(ssmA);var ssmText=document.createElement("span");ssmText.setAttribute("style","display: block;font-size: 11px;line-height: 13px;color;gray");ssmText.innerHTML='Watch an ad to download Wallpapper';})}}
run(button){console.log("SSM => run SS+SponsorWall");googletag.cmd.push(()=>{googletag.pubads().addEventListener('rewardedSlotClosed',event=>{googletag.destroySlots([event.slot])});googletag.pubads().addEventListener('rewardedSlotGranted',event=>{document.querySelectorAll("a.ssmButton").forEach((ssmbutton)=>{ssmbutton.remove();});document.querySelectorAll("div.flexbox_item.bottom_panel a.download_button").forEach((originalbutton)=>{originalbutton.style.display='inherit';});if(document.getElementById("ssmPremiumContainer")){document.getElementById("ssmPremiumContainer").remove();}
googletag.destroySlots([window.ssmRegardedSlot]);window.location.href=button.href;});googletag.pubads().addEventListener("slotRenderEnded",(event)=>{if(event.slot.getAdUnitPath()==window.ssmRegardedSlot.getAdUnitPath()){if(event.isEmpty){document.querySelectorAll("a.ssmButton").forEach((ssmbutton)=>{ssmbutton.remove();});document.querySelectorAll("div.flexbox_item.bottom_panel a.download_button").forEach((originalbutton)=>{originalbutton.style.display='inherit';});if(document.getElementById("ssmPremiumContainer")){document.getElementById("ssmPremiumContainer").remove();}
googletag.destroySlots([window.ssmRegardedSlot]);window.location.href=button.href;}}});});}
showRegarded(){window.ssmDispatchRegardedEvent.makeRewardedVisible();}
maxZIndex(){let zIndex=Array.from(document.querySelectorAll('body *')).map(a=>parseFloat(window.getComputedStyle(a).zIndex)).filter(a=>!isNaN(a)).sort().pop();if(this.config.topZindex){if(document.querySelector(this.config.topZindex)){if(document.querySelector(this.config.topZindex).zIndex!=""){zIndex=document.querySelector(this.config.topZindex).zIndex-1;}}}
return zIndex;}}
const ssmPremium=new ssmPremiumContent(ssmPremiumConfig);